{
  "name": "oge-english-dashboard",
  "version": "1.0.1b",
  "private": true,
  "type": "module",
  "scripts": {
    "build:data": "node scripts/generate-report-data.mjs",
    "import:oge-materials": "python3 scripts/import-oge-materials.py",
    "refresh:reports": "node scripts/import-excel.mjs && node scripts/generate-report-data.mjs",
    "start": "node scripts/start-all.mjs",
    "stop": "node scripts/stop-services.mjs",
    "pb:serve": "./pocketbase/pocketbase serve --http=127.0.0.1:8091 --dir ./pocketbase/pb_data",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "import:excel": "node scripts/import-excel.mjs"
  },
  "dependencies": {
    "express": "^4.21.2",
    "puppeteer-core": "^21.11.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@vitejs/plugin-react": "4.2.1",
    "typescript": "5.3.3",
    "vite": "4.5.3"
  }
}
